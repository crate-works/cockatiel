---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — Cockatiel">
  <section class="mx-auto flex max-w-xl flex-col items-center px-6 py-28 text-center">
    <p class="text-sm font-medium tracking-wide text-brand uppercase">404</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight">Page not found</h1>
    <p class="mt-4 text-muted-foreground">
      The page you're looking for doesn't exist. Try the app, or head back home.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/app"
        class="rounded-lg bg-brand px-6 py-3 font-semibold text-brand-foreground transition-opacity hover:opacity-90"
      >
        Open Cockatiel →
      </a>
      <a
        href="/"
        class="rounded-lg border border-border bg-card px-6 py-3 font-medium transition-colors hover:bg-muted"
      >
        Back home
      </a>
    </div>
  </section>
</Layout>
