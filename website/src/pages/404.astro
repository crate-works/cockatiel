---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — Cockatiel">
  <script is:inline slot="head">
    // GitHub Pages serves this single root 404.html for every unknown path — it
    // never falls back to a subdirectory's 404.html. The app is a client-side SPA
    // mounted at /app/, so deep links and refreshes under /app/ (e.g. /app/catalog,
    // /app/session/...) land here. Encode the requested path into a `?/`-prefixed
    // query and bounce to the SPA entry, which restores the real URL before the
    // router boots (see the decode shim in the app's index.html). Non-/app/ paths
    // fall through to the marketing 404 rendered below.
    //
    // The OAuth callback (/app/auth/callback) is a real materialised file (see
    // scripts/build-deploy.sh), so it is served directly and never reaches here —
    // its sensitive code/state params are never run through this encoding.
    ((l) => {
      const base = '/app';
      if (l.pathname !== base && !l.pathname.startsWith(`${base}/`)) {
        return;
      }
      // Let real file requests (anything with an extension, e.g. a missing JS
      // chunk) 404 normally rather than bouncing HTML into the SPA.
      const last = l.pathname.split('/').pop();
      if (last?.includes('.')) {
        return;
      }
      const path = l.pathname.slice(base.length + 1).replace(/&/g, '~and~');
      const query = l.search ? `&${l.search.slice(1).replace(/&/g, '~and~')}` : '';
      l.replace(`${l.protocol}//${l.host}${base}/?/${path}${query}${l.hash}`);
    })(window.location);
  </script>

  <section class="mx-auto flex max-w-xl flex-col items-center px-6 py-28 text-center">
    <p class="text-sm font-medium tracking-wide text-brand uppercase">404</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight">Page not found</h1>
    <p class="mt-4 text-muted-foreground">
      The page you're looking for doesn't exist. Try the app, or head back home.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/app"
        class="rounded-lg bg-brand px-6 py-3 font-semibold text-brand-foreground transition-opacity hover:opacity-90"
      >
        Open Cockatiel →
      </a>
      <a
        href="/"
        class="rounded-lg border border-border bg-card px-6 py-3 font-medium transition-colors hover:bg-muted"
      >
        Back home
      </a>
    </div>
  </section>
</Layout>
